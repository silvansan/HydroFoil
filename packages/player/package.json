{
  "name": "@hydrofoil/player",
  "version": "0.1.0",
  "description": "Branded HydroFoil embed player (HLS / VOD)",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./embed": {
      "types": "./src/embed.ts",
      "import": "./src/embed.ts",
      "default": "./src/embed.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run --passWithNoTests",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "dependencies": {
    "hls.js": "^1.6.16",
    "mpegts.js": "^1.8.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "typescript": "^5.1.0",
    "vitest": "^3.2.4"
  }
}
