    "@hydrofoil/srs-adapter": "*",
    "@hydrofoil/storage": "*",
    "@hydrofoil/shared-types": "*",
    "pg": "^8.11.0",
    "redis": "^4.6.0",
    "bull": "^4.11.0",
    "pino": "^8.16.0",
    "ffmpeg": "^0.0.4",
    "fluent-ffmpeg": "^2.1.2"
  },
  "devDependencies": {
    "typescript": "^5.1.0",
    "tsx": "^3.14.0",
    "@types/node": "^20.0.0",
    "@types/bull": "^3.15.0",
    "@types/node": "^20.0.0",
    "vitest": "^0.34.0"
  }
