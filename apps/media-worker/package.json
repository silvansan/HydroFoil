    "lint": "tsc --noEmit",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@hydrofoil/domain": "*",
    "@hydrofoil/db": "*",
    "@hydrofoil/events": "*",
