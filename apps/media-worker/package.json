{
  "name": "@hydrofoil/media-worker",
  "version": "0.1.0",
  "description": "Queue-driven media worker for HydroFoil",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
