# =============================================================================
# HydroFoil — Portainer stack environment variables
# =============================================================================
#
# HOW TO USE IN PORTAINER (no SSH required if you use Git deploy — see README):
#
#   1. Stacks → Add stack → choose Git repository (recommended) OR Web editor
#   2. Paste / point to: deploy/portainer/PORTAINER_STACK.yml
#   3. Open "Environment variables" → "Advanced mode"
#   4. Either:
#        • Upload file: .env.copypaste (after you edit CHANGE_ME values), or
#        • Copy each KEY=value line below into the stack env section
#   5. Replace every CHANGE_ME value. DATABASE_URL password must match POSTGRES_PASSWORD.
#   6. Deploy the stack
#
# First login: DEFAULT_ADMIN_EMAIL / DEFAULT_ADMIN_PASSWORD → change password in My profile.
#
# =============================================================================

# Pre-built images (default PORTAINER_STACK.yml — no source code on the server)
HYDROFOIL_IMAGE_REGISTRY=ghcr.io/silvansan
HYDROFOIL_IMAGE_TAG=latest

# --- PostgreSQL ---
POSTGRES_DB=hydrofoil
POSTGRES_USER=hydrofoil
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
DATABASE_URL=postgresql://hydrofoil:CHANGE_ME_STRONG_DB_PASSWORD@postgres:5432/hydrofoil

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- MinIO (local object storage) ---
MINIO_ROOT_USER=CHANGE_ME_MINIO_USER
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=CHANGE_ME_MINIO_USER
MINIO_SECRET_KEY=CHANGE_ME_MINIO_PASSWORD
MINIO_USE_SSL=false
# Hostname for signed URLs in browsers (no https:// prefix), e.g. media.example.com:9000
MINIO_PUBLIC_ENDPOINT=CHANGE_ME_PUBLIC_HOST:9000

# --- Published ports on the Docker host (3080 avoids common 3000 conflicts e.g. Portainer) ---
ADMIN_UI_PORT=3080
CONTROL_API_PORT=3001
SRS_RTMP_PORT=1935
SRS_HTTP_PORT=8080
SRS_API_PORT=1985
SRS_SRT_PORT=10080
SRS_WEBRTC_UDP_PORT=8000
SRS_WEBRTC_TCP_PORT=8000

# --- Public URLs (emails, docs, encoder hints) ---
# HTTPS URL where operators open the admin console (your reverse proxy hostname)
PUBLIC_APP_URL=https://hydrofoil.CHANGE_ME.example.com
# Internal SRS HTTP playback (control-api → srs on Docker network). Do not use the public URL here.
SRS_PLAYBACK_BASE_URL=http://srs:8080
# Public RTMPS ingest URL shown in the admin UI (OBS/vMix copy link) — external relay port
SRS_RTMP_FORWARD_BASE=rtmps://hydrofoil.CHANGE_ME.example.com:1936
# Hostname from PUBLIC_APP_URL — SRS appends an HLS-enabled vhost for RTMPS publishers (required for web embed)
SRS_INGEST_VHOST=hydrofoil.CHANGE_ME.example.com
SRS_RTMP_READ_BASE=rtmp://srs:1935
# Optional; defaults to hostname from PUBLIC_APP_URL or SRS_RTMP_FORWARD_BASE
SRS_SRT_PUBLIC_HOST=
SRS_SRT_PUBLIC_PORT=10080
SRS_HTTP_API_URL=http://srs:1985
SRS_WEBHOOK_SECRET=CHANGE_ME_RANDOM_WEBHOOK_SECRET

# --- Security (use long random strings, 32+ characters) ---
AUTH_TOKEN_SECRET=CHANGE_ME_AUTH_JWT_SECRET_MIN_32_CHARS
PLAYBACK_TOKEN_SECRET=CHANGE_ME_PLAYBACK_SECRET_MIN_32_CHARS
PLAYBACK_TOKEN_TTL_SECONDS=3600
STORAGE_SECRET_KEY=CHANGE_ME_STORAGE_ENCRYPTION_KEY_MIN_32_CHARS

# --- Bootstrap admin (created on first control-api start if missing) ---
DEFAULT_ORGANIZATION_SLUG=default
DEFAULT_ADMIN_EMAIL=admin@CHANGE_ME.example.com
DEFAULT_ADMIN_PASSWORD=CHANGE_ME_INITIAL_ADMIN_PASSWORD
DEFAULT_ADMIN_DISPLAY_NAME=HydroFoil Admin
DEFAULT_ADMIN_ROLE=super-admin
# Set true once to reset the bootstrap admin password from DEFAULT_ADMIN_PASSWORD, then set back to false.
DEFAULT_ADMIN_SYNC_PASSWORD=false
DEFAULT_ADMIN_ACTIVE=true
RUN_MIGRATIONS_ON_START=true

# --- SMTP (optional — leave SMTP_HOST empty to disable outbound mail) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_ADMIN_TO=

# --- Media worker / admin UI build ---
RECORDING_TRANSCODE_HLS=true
VITE_WEBRTC_ICE_SERVERS=stun:stun.l.google.com:19302
