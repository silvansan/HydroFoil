# Environment Variables (copy to .env and fill in actual values)

# Database
DATABASE_URL=postgresql://hydrofoil:hydrofoil_dev@localhost:5432/hydrofoil

# Redis
REDIS_URL=redis://localhost:6379

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_PUBLIC_ENDPOINT=localhost:9000

# Storage provider credentials
# Set this before adding remote S3 locations in production. New per-location
# access/secret keys are encrypted with this value; existing plaintext dev keys
# remain readable for local compatibility.
STORAGE_SECRET_KEY=

# Media worker
# Set to 0 to disable expired source FLV cleanup.
SOURCE_FLV_CLEANUP_INTERVAL_MS=3600000

# SRS media engine
SRS_HTTP_API_URL=http://localhost:1985
SRS_RTMP_URL=rtmp://localhost:1935/live
SRS_WEBHOOK_SECRET=

# Node environment
NODE_ENV=development

# Application ports
CONTROL_API_PORT=3001
ADMIN_UI_PORT=3000

# Admin UI / WebRTC monitor
# Comma-separated STUN/TURN URLs for WHEP monitor mode.
VITE_WEBRTC_ICE_SERVERS=stun:stun.l.google.com:19302
VITE_REPOSITORY_URL=https://github.com/silvansan/HydroFoil
VITE_LICENSE_LABEL=AGPL-3.0

# Test gates
RUN_INTEGRATION_TESTS=false
RUN_FFMPEG_INTEGRATION_TESTS=false
STORAGE_SERVICE_PORT=3002
